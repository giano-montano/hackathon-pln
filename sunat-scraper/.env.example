# Copia este archivo a .env y ajusta los valores.
# Ninguna variable es obligatoria: todas tienen un valor por defecto en config/sources.yaml.
#
# NUNCA guardes aqui credenciales de SUNAT (Clave SOL, usuario, RUC con clave).
# El scraper solo lee paginas publicas y jamas accede a zonas autenticadas.

# User-Agent identificable enviado en cada peticion.
SUNAT_SCRAPER_USER_AGENT="sunat-scraper/0.1 (+corpus RAG educativo; contacto: tu-correo@ejemplo.pe)"

# Maximo de solicitudes por segundo (float).
SUNAT_SCRAPER_REQUESTS_PER_SECOND=1

# Timeout por peticion, en segundos.
SUNAT_SCRAPER_TIMEOUT=30

# Directorio base de salida.
SUNAT_SCRAPER_DATA_DIR=data
